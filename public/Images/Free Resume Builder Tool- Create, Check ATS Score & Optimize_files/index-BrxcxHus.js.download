.ai-enhanced-badge {
    background: linear-gradient(135deg, #8b5cf6, #7c3aed);
    color: white;
    padding: 3px 8px;
    border-radius: 12px;
    font-size: 10px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.6px;
    box-shadow: 0 2px 8px rgba(139, 92, 246, 0.3);
    animation: glow 3s ease-in-out infinite alternate;
}

@media (min-width: 640px) {
    .ai-enhanced-badge {
        padding: 4px 12px;
        border-radius: 16px;
        font-size: 11px;
        letter-spacing: 0.8px;
        box-shadow: 0 2px 10px rgba(139, 92, 246, 0.3);
    }
}

@keyframes glow {
    0% { box-shadow: 0 2px 8px rgba(139, 92, 246, 0.3); }
    100% { box-shadow: 0 4px 15px rgba(139, 92, 246, 0.6); }
}

@media (min-width: 640px) {
    @keyframes glow {
        0% { box-shadow: 0 2px 10px rgba(139, 92, 246, 0.3); }
        100% { box-shadow: 0 4px 20px rgba(139, 92, 246, 0.6); }
    }
}
